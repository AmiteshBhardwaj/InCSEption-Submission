{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --prefix zebra-synapse",
  "buildCommand": "npm run build --prefix zebra-synapse",
  "outputDirectory": "zebra-synapse/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
